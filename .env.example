# Supabase REST API settings.
# These VITE_* values are exposed to the browser by Vite.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional browser-side allowlist for friendlier private-household auth errors.
# Keep Supabase public sign-up disabled and manually create the two users.
VITE_APPROVED_HOUSEHOLD_EMAILS=matt@example.com,spouse@example.com

# Google Calendar OAuth settings.
# Use an OAuth web client with every local/deployed app origin configured
# in Google Cloud Console Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CALENDAR_ID=primary

# Server-only Anthropic key used by api/brief.js.
# Do not add this value to frontend code.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Comma-separated browser origins allowed to call api/brief.js.
# VERCEL_URL is allowed automatically by Vercel deployments.
ALLOWED_ORIGINS=http://localhost:3000,https://your-familyos-domain.vercel.app
