# Supabase REST API settings.
# These values are exposed to the browser by Create React App.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional browser-side allowlist for friendlier private-household auth errors.
# Keep Supabase public sign-up disabled and manually create the two users.
REACT_APP_APPROVED_HOUSEHOLD_EMAILS=matt@example.com,spouse@example.com

# Google Calendar OAuth settings.
# Use an OAuth web client with every local/deployed app origin configured
# in Google Cloud Console Authorized JavaScript origins.
REACT_APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
REACT_APP_GOOGLE_CALENDAR_ID=primary

# Release 0.8 server-side Google Calendar foundation.
# These values must remain server-only in Vercel/API environments.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Development test infrastructure. Keep passwords and service-role keys only in
# ignored local/test environment files. Auto-login is additionally restricted
# in code to localhost development builds and cannot run in preview/production.
FAMILYOS_ENV=test
DEMO_USER_EMAIL=test@familyos.app
DEMO_USER_PASSWORD=use-a-strong-local-secret
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_SKIP_WEBSERVER=false
DEMO_SEED_ALLOW_REMOTE_TEST=false
DEMO_SEED_EXPECTED_PROJECT_REF=your-non-production-project-ref
# Alternative exact target for local Supabase: http://127.0.0.1:54321
DEMO_SEED_EXPECTED_URL=
REACT_APP_ENABLE_DEMO_AUTO_LOGIN=false
REACT_APP_ENABLE_ADVISORY_API=false
REACT_APP_DEMO_EMAIL=test@familyos.app
REACT_APP_DEMO_PASSWORD=use-the-same-local-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-familyos-domain.vercel.app/api/calendar?action=callback
GOOGLE_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key-for-token-encryption
GOOGLE_OAUTH_STATE_SECRET=your-random-state-signing-secret
GOOGLE_CALENDAR_ID=primary
APP_BASE_URL=https://your-familyos-domain.vercel.app

# Server-only AI provider configuration. AI_PROVIDER defaults to anthropic;
# use mock for deterministic automated environments. Never add keys to REACT_APP_*.
AI_PROVIDER=anthropic
AI_PROVIDER_MODEL=claude-sonnet-4-6
AI_REQUEST_TIMEOUT_MS=15000
AI_PROVIDER_API_KEY=
ANTHROPIC_API_KEY=your-anthropic-api-key

# Comma-separated browser origins allowed to call server APIs.
# VERCEL_URL is allowed automatically by Vercel deployments.
ALLOWED_ORIGINS=http://localhost:3000,https://your-familyos-domain.vercel.app
