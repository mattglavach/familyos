{
  "name": "familyos",
  "version": "1.8.3",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.15",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "3.4.19"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint src --ext .js,.jsx",
    "test": "react-scripts test --watchAll=false",
    "check": "pnpm run lint && pnpm run test && pnpm run test:seed-guards && pnpm run build && pnpm run test:bundle-safety",
    "test:seed-guards": "node --test scripts/lib/demoSeedSafety.test.mjs",
    "test:bundle-safety": "node scripts/check-production-bundle.mjs",
    "test:db-bootstrap": "node scripts/validate-supabase-bootstrap.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "test:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:smoke:desktop": "playwright test --project=chromium tests/e2e/smoke.spec.js",
    "test:smoke:mobile": "playwright test --project=mobile-chromium tests/e2e/smoke.spec.js",
    "test:regression": "pnpm run seed:demo && playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "dotenv": "^17.4.2",
    "eslint": "8.57.1"
  }
}
