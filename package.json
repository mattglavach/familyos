{
  "name": "familyos",
  "version": "3.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.15",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "3.4.19"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint src --ext .js,.jsx",
    "test": "react-scripts test --watchAll=false",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:db-2.9 && pnpm run test:db-2.10 && pnpm run test:db-2.10.1 && pnpm run test:seed-guards && pnpm run build && pnpm run test:bundle-safety",
    "test:seed-guards": "node --test scripts/lib/demoSeedSafety.test.mjs",
    "test:bundle-safety": "node scripts/check-production-bundle.mjs",
    "test:accessibility": "playwright test tests/e2e/accessibility.spec.js",
    "test:db-bootstrap": "node scripts/validate-supabase-bootstrap.mjs",
    "test:db-upgrade-2.5": "node scripts/validate-release-2.5-upgrade.mjs",
    "test:db-2.9": "node scripts/validate-release-2.9.mjs",
    "test:db-2.10": "node scripts/validate-release-2.10.mjs",
    "test:db-2.10.1": "node scripts/validate-release-2.10.1.mjs",
    "test:storage": "node scripts/validate-storage-flow.mjs",
    "test:production": "node scripts/verify-production.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck src/services/contextEngine.d.ts src/services/timeline.d.ts",
    "test:pool-migration": "node scripts/validate-pool-schema-reconciliation.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "test:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:smoke:desktop": "playwright test --project=chromium tests/e2e/smoke.spec.js",
    "test:smoke:mobile": "playwright test --project=mobile-chromium tests/e2e/smoke.spec.js",
    "test:smoke:tablet": "playwright test --project=tablet-chromium tests/e2e/smoke.spec.js",
    "test:smoke:dark": "playwright test --project=dark-chromium tests/e2e/smoke.spec.js",
    "test:regression": "pnpm run seed:demo && playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "dotenv": "^17.4.2",
    "eslint": "8.57.1"
  }
}
